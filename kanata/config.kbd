(defchordsv2

  (r e lmet) (multi lmet lsft) $chord-time first-release () ;; Shift + Meta (Left-hand)
  (u i rmet) (multi rmet rsft) $chord-time first-release () ;; Shift + Meta (Rigth-hand)

  (w r lmet) (multi lsft lctl) $chord-time first-release () ;; Shift + Control (Left-hand)
  (u o rmet) (multi lsft lctl) $chord-time first-release () ;; Shift + Control (Rigth-hand)

  (w e lmet) (multi lmet lctl) $chord-time first-release () ;; Meta + Control (Left-hand)
  (i o rmet) (multi rmet rctl) $chord-time first-release () ;; Meta + Control (Rigth-hand)

  (q e lmet) (multi lmet ralt) $chord-time first-release () ;; Meta + alt (Left-hand)
  (i p rmet) (multi rmet ralt) $chord-time first-release () ;; Meta + alt (Rigth-hand)

  (q r lmet) (multi ralt lsft) $chord-time first-release () ;; Alt + Shift (left-hand)
  (p u rmet) (multi ralt rsft) $chord-time first-release () ;; Alt + Shift (left-hand)

  (q lmet) ralt $chord-time first-release ()
  (w lmet) lctl $chord-time first-release ()
  (e lmet) lmet $chord-time first-release ()
  (r lmet) lsft $chord-time first-release ()

  (u rmet) rsft $chord-time first-release ()
  (i rmet) rmet $chord-time first-release ()
  (o rmet) lctl $chord-time first-release ()
  (p rmet) ralt $chord-time first-release ()

  (spc tab) (layer-toggle number) $chord-time first-release ()

  (a lmet) (layer-toggle apps) $chord-time first-release ()
  (f lmet) (layer-toggle sesionLayer) $chord-time first-release ()
  (d lmet) (layer-toggle SpaceLayer) $chord-time first-release ()
  (s lmet) (layer-toggle TabLayer) $chord-time first-release ()


  (k rmet) (layer-toggle TerminalPaneLayer) $chord-time first-release ()
  (l rmet) (layer-toggle WindowsLayer) $chord-time first-release ()
  (j rmet) (layer-toggle TerminalLayer) $chord-time first-release ()


)

(defalias

   spa_slyr (layer-toggle SpaceSubLayer)
   win_slyr (layer-toggle WindowsSubLayer)
   apps_lyr (layer-toggle apps)
   sesn_lyr (layer-toggle sesionLayer)
   tabs_lyr (layer-toggle TabLayer)
   tPanelyr (layer-toggle TerminalPaneLayer)
   winOSlyr (layer-toggle WindowsLayer)
   termnLyr (layer-toggle TerminalLayer)






   Lhypr_lyr (tap-hold-press  $tap-time $hold-time @hrow_cl (layer-toggle HyperKeyLayer))
   MRsft_lyr (tap-hold-press  $tap-time $hold-time XX (layer-toggle RightShift))
   Rhypr_lyr (tap-hold-press  $tap-time $hold-time @hrow_sc (layer-toggle HyperKeyLayer))
   MLsft_lyr (tap-hold-press  $tap-time $hold-time XX (layer-toggle LeftShift))


   Cntrl_lyr (tap-hold-press  $tap-time $hold-time bspc (layer-toggle ControlLayer))
   RiCntrl_lyr (tap-hold-press  $tap-time $hold-time ret  (layer-toggle RightControlLayer))
   nav_lyr (layer-toggle navigationLayer)

   num_lyr (tap-hold $tap-time $hold-time spc (layer-toggle number))




  sys_lyr (tap-hold $tap-time $hold-time z (layer-toggle systemLayer)) ;; trickster

   scr_lyr (tap-hold $tap-time $hold-time @{ (layer-toggle ScreenShotLayer))

)

(defalias 

  @_1fill (tap-hold $tap-time $hold-time @@ C-A-M-p) ;; trickster
  %_1pass (tap-hold $tap-time $hold-time @% S-C-A-M-p) ;; trickster
  {_zappy (tap-hold $tap-time $hold-time @{ C-A-M-z) ;; trickster
  cpy (tap-hold $tap-time $hold-time M-v M-c) ;;Copy paste
)

(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  102d 1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab q    w    e    r    t    y    u    i    o    p    [    ]    ret
  caps a    s    d    f    g    h    j    k    l    ;    '    \
  lsft grv z    x    c    v    b    n    m    ,    .    /    rsft
  fn lctl lalt lmet           spc           rmet ralt left down up   rght
)

(deflayer base
  @cpy  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  caps  @~ @[ @scr_lyr     @pl   @%_1pass   @$     @pr    @}   @]     @+    @`    @#    XX
  tab '    ,    .    p    y    f    g    c r l    @/    @@_1fill    XX
  esc a    o   e   u     i    d    h    t    n  s -    \
  @MLsft_lyr @MLsft_lyr    @;       q    j    k       x        b    m    w    v    @sys_lyr    @MRsft_lyr
  lmet XX @Lhypr_lyr    @Cntrl_lyr           @num_lyr           @RiCntrl_lyr    @Rhypr_lyr left down up   rght
)

