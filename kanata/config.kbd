(defcfg
  process-unmapped-keys yes
  danger-enable-cmd yes
  concurrent-tap-hold yes
)


(defvar
  tap-time 10 ;; Deshabilitamos el tapcontinous porque interfiere con mi num_lyr

  hold-time  200
  subl-time 200
 tmux-delay 40
 chord-time 250
)
(defalias
 ;;Raycast variables

 c_clipb (cmd open raycast://extensions/raycast/clipboard-history/clipboard-history)
 k_killp (cmd open raycast://extensions/rolandleth/kill-process/index) ;;It's similar to Activity Monitor
 b_raind (cmd open raycast://extensions/lardissone/raindrop-io/search) ;; Invoke 'raindrop.io search bookmarks'(Raycast's plugin). Plus, Raindrop.io is page for save all your bookmarks for use in anywhre
 y_ytvid (cmd open raycast://extensions/tonka3000/youtube/search-videos?arguments=%7B%22query%22%3A%22%22%7D) ;;Invoke 'Youtube Search' (Plugin) find videos with autosuggestion anywhere and open direct
 e_emoji (cmd open raycast://extensions/raycast/emoji-symbols/search-emoji-symbols) ;;Invoke 'emoji-symbols' (Native)
 f_files (cmd open raycast://extensions/raycast/file-search/search-files) 
 g_googl (cmd open raycast://extensions/mblode/google-search/index) ;;Invoke 'Google Search' (Plugin) Search in google with autosuggestion anywhere and open direct in new tab 
 h_gihub (cmd open raycast://extensions/raycast/github/search-repositories) ;; Invoke 'Github search repositories'(Plugin)
 d_dwnYT (cmd open raycast://extensions/vimtor/video-downloader/index) ;; Youtube video-downloader with  'yt-dlp'(github)
)

(defalias

;; Nota importante. Debido a que El root no puede acceder a algunos archivos del los usuarios 
;; En este caso (usuario: liusam) y mi archivo '/tmp/yabai_liusam.socket', Kanata no puede hacer 
;; contacto con el socket de yabai debido a que el comando con el que se inicia el servicio de Kanata 
;; (sudo your/path/kanata -c your/file/config.kbd) entra como modo root. Por ello, es 
;; necesario mediante este archivo.kbd indicarle que para ejecutar un command  de yabai 
;; (Por ejemplo 'yabai -m space --destroy') lo haga como usuario donde actual (sudo -u liusam)
  v_creat (cmd sudo -u liusam yabai -m space --create)
  w_destr (cmd sudo -u liusam yabai -m space --destroy)

  h_spac1 (cmd sudo -u liusam yabai -m space --focus 1)
  t_spac2 (cmd sudo -u liusam yabai -m space --focus 2)
  n_spac3 (cmd sudo -u liusam yabai -m space --focus 3)
  g_spac4 (cmd sudo -u liusam yabai -m space --focus 4)
  c_spac5 (cmd sudo -u liusam yabai -m space --focus 5)
  r_spac6 (cmd sudo -u liusam yabai -m space --focus 6)
  7_spac7 (cmd sudo -u liusam yabai -m space --focus 7)
  8_spac8 (cmd sudo -u liusam yabai -m space --focus 8)
  9_spac9 (cmd sudo -u liusam yabai -m space --focus 9)
  lastSpc (cmd sudo -u liusam yabai -m space --focus recent)
  )

(defalias

  r_resta (cmd "/Users/liusam/dotfiles/yabai/restartGUI.sh")
  s_split (cmd sudo -u liusam yabai -m window --toggle split)
  x_close (cmd sudo -u liusam bash -c "yabai $(yabai -m window $(yabai -m query --windows --window | jq -re '.id') --close)")
  m_minim (cmd sudo -u liusam yabai -m window --minimize)
  b_remin (cmd sudo -u liusam yabai -m window --deminimize)

  h_westt (cmd sudo -u liusam yabai -m window --focus west)
  t_south (cmd sudo -u liusam yabai -m window --focus south)
  c_north (cmd sudo -u liusam yabai -m window --focus north)
  n_eastt (cmd sudo -u liusam yabai -m window --focus east)

  z_fulls (cmd sudo -u liusam yabai -m window --toggle zoom-fullscreen)
  i_stick (cmd sudo -u liusam yabai -m window --toggle sticky)

  9_rot90 (cmd sudo -u liusam yabai -m space --rotate 270) ;; 90 degrees for anti-clockwise
                                                            ;;270 degrees to clocwise
  8_flipY (cmd sudo -u liusam yabai -m space --mirror y-axis)
  7_flipX (cmd sudo -u liusam yabai -m space --mirror x-axis)

  e_bsppp (cmd sudo -u liusam yabai -m space --layout bsp)
  o_float (cmd sudo -u liusam yabai -m space --layout float)
  u_stack (cmd sudo -u liusam yabai -m space --layout stack)
 ;;
  )

