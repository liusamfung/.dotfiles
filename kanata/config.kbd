(defalias
 b_prviw (macro C-x $tmux-delay w) ;; -> Preview list of windows(tabs) and sessions
 w_clsTb (macro C-x $tmux-delay @&) ;;  -> Quit current tab. (TmuxPrefix + &) 
 v_crtTb (macro C-x $tmux-delay c) ;;  -> Kreate new tab (TmuxPrefix + c)
 r_rnmTb (macro C-x $tmux-delay ,) ;; -> Rename current window (TmuxPrefix + ,)

 h_goTb1 (macro C-x $tmux-delay h) ;; -> -> Go to tab number 1
 t_goTb2 (macro C-x $tmux-delay j) ;; -> -> Go to tab number 2
 n_goTb3 (macro C-x $tmux-delay k) ;; -> -> Go to tab number 3
 g_goTb4 (macro C-x $tmux-delay l) ;; -> -> Go to tab number 4
 c_goTb5 (macro C-x $tmux-delay y) ;; -> -> Go to tab number 5

 ;;       [:dvrk-h [:!Tx :h]] ; (t + h) 
 ;;       [:dvrk-t [:!Tx :j]] ; (t + j) -> Go to tab number 2
 ;;       [:dvrk-n [:!Tx :k]] ; (t + k) -> Go to tab number 3
 ;;       [:dvrk-g [:!Tx :l]] ; (t + l) -> Go to tab number 4
 ;;       [:dvrk-c [:!Tx :y]] ; (t + y) -> Go to tab number 5
)

