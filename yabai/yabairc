##################################Especific rules (OUTLOOK)#######################################################################
# https://github.com/asmvik/yabai/blob/master/doc/yabai.asciidoc#rule
# Hacemos que cualquier ventana de Outlook cuyo título NO sea exactamente el del buzón (es decir, un correo individual) FLOTE.
# (Esto captura la estructura 'Asunto - Carpeta • Email')
yabai -m rule --add app="^Microsoft Outlook$" \
    title="^.* - .* • .*$" \
    manage=off \
    opacity=0.98 \
    # grid="1:1:0:200:900:1000" # Usando grid para el tamaño

# Ventanas de composición de correo nuevo (patrón: Asunto • Email)
# Nota: "Untitled" puede cambiar al escribir el asunto, por lo que usamos ^.* para capturar cualquier asunto.
yabai -m rule --add app="^Microsoft Outlook$" \
    title="^Untitled • .*@.*$" \
    manage=off \
    opacity=0.98 \
    # grid="1:1:0:200:900:1000" # Usando grid para el tamaño
