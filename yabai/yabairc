# Enfocar automáticamente cualquier ventana nueva al crearse
# El problema es que las reglas (rules) de Yabai mueven la ventana antes de que el sistema operativo termine de asignarle el foco, o el cambio de espacio interrumpe la solicitud de foco.
# Necesitas un signal que detecte cuando una ventana nueva nace y fuerce el foco inmediatamente sobre ella, usando su ID específico.
yabai -m signal --add event=window_created action="yabai -m window \$YABAI_WINDOW_ID --focus"

# Forzar foco a la ventana que esta debajo del mouse cada vez que se cambia de espacio.
# Si solo hay una ventan activa en el stack del espacio actual, entonces se activa el signal, sino, no.
# yabai -m signal --add event=space_changed action="[ $(yabai -m query --windows --space | jq '. | length') -eq 1 ] && yabai -m window --focus mouse"

yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=window_minimized action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=application_hidden action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=application_terminated action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"

