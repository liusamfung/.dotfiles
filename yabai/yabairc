# Enfocar automáticamente cualquier ventana nueva al crearse
# El problema es que las reglas (rules) de Yabai mueven la ventana antes de que el sistema operativo termine de asignarle el foco, o el cambio de espacio interrumpe la solicitud de foco.
# Necesitas un signal que detecte cuando una ventana nueva nace y fuerce el foco inmediatamente sobre ella, usando su ID específico.
yabai -m signal --add event=window_created action="yabai -m window \$YABAI_WINDOW_ID --focus"

# Forzar foco a la ventana que esta debajo del mouse cada vez que se cambia de espacio.
# Si solo hay una ventan activa en el stack del espacio actual, entonces se activa el signal, sino, no.
# yabai -m signal --add event=space_changed action="[ $(yabai -m query --windows --space | jq '. | length') -eq 1 ] && yabai -m window --focus mouse"

yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=window_minimized action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=application_hidden action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=application_terminated action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"




# yabai -m query --windows | grep app
apps_terminal="(kitty)"
apps_testing="(Google Chrome|Bruno|Postman)" # I test web development stuff with Google Chrome
apps_organization="(Fantastical|Reminders|Notion|Obsidian)"
apps_workspace="(Canva|Microsoft Excel|Microsoft Word|Microsoft PowerPoint)"
apps_media="(Firefox|Preview|Microsoft Teams|zoom.us|Photos|YouTube Music|Brave Browser|Spotify)" #Generalmente solo usas una de estas apps a la vez
# apps_msg="(net.whatsapp.WhatsApp)" 
  apps_msg="(Microsoft Outlook|WhatsApp|Slack)" 
apps_msg="(Microsoft Outlook|Slack)" 
apps_browsing="(Zen)" # 
apps_record="(OBS Studio)" # 

apps_mgoff_normal="(Clock|Quick Camera|Photo Booth|QuickTime Player|System Preferences|System Settings|Terminal|Godot|Shottr|Notes|IINA)" #Apps no administradas por yabai(Por defecto, flat)

apps_known="${apps_terminal}|${apps_testing}|${apps_organization}|${apps_workspace}|${apps_media}|${apps_msg}|${apps_browsing}|${apps_record}|${apps_mgoff_normal}"


yabai -m rule --add app="^${apps_terminal}$"  space=^1 # Terminal 
yabai -m rule --add app="^${apps_testing}$"  space=^2 # Workspace to testing 
yabai -m rule --add app="^${apps_workspace}$"  space=^3 # Worktyping or others (Canva, Word, Excel)
yabai -m rule --add app="^${apps_organization}$"  space=^4 # Organización (Fantastical, Reminders, Notion, etc)
yabai -m rule --add app="^${apps_media}$"  space=^5 # Media (Watch, pdf, videos, images, etc)
# yabai -m rule --add app="^Shottr$"  space=^5 #Forzar que se habra en el espcio 5, pero Yabai no va a manejarlo.
yabai -m rule --add app="^${apps_browsing}$"  space=^6 
# Esta regla dice: Si la app NO coincide con nada en $apps_known, muévela al espacio 7.
# yabai -m rule --add app="^(?!(${apps_known})$).*$" space=^7
yabai -m rule --add app="^${apps_msg}$"  space=^8
yabai -m rule --add app="^${apps_record}$"  space=^9

yabai -m rule --add app="^${apps_mgoff_normal}$" manage=off


# Regla Final (La más segura): Ignorar cualquier ventana de Outlook que NO sea una ventana estándar (p.ej., pop-ups de calendario, alertas, etc.)
# Aunque tus ejemplos son AXStandardWindow, esto es buena práctica:
# yabai -m rule --add app="^Microsoft Outlook$" subrole!="AXStandardWindow" manage=off
##################################Especific rules (OUTLOOK)#######################################################################
# https://github.com/asmvik/yabai/blob/master/doc/yabai.asciidoc#rule
# Hacemos que cualquier ventana de Outlook cuyo título NO sea exactamente el del buzón (es decir, un correo individual) FLOTE.
# (Esto captura la estructura 'Asunto - Carpeta • Email')
yabai -m rule --add app="^Microsoft Outlook$" \
    title="^.* - .* • .*$" \
    manage=off \
    opacity=0.98 \
    # grid="1:1:0:200:900:1000" # Usando grid para el tamaño

# Ventanas de composición de correo nuevo (patrón: Asunto • Email)
# Nota: "Untitled" puede cambiar al escribir el asunto, por lo que usamos ^.* para capturar cualquier asunto.
yabai -m rule --add app="^Microsoft Outlook$" \
    title="^Untitled • .*@.*$" \
    manage=off \
    opacity=0.98 \
    # grid="1:1:0:200:900:1000" # Usando grid para el tamaño
##################################Especific rules ()#######################################################################



